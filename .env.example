# =============================================================
# Пример файла переменных окружения.
# Скопируйте этот файл в .env и заполните своими значениями.
# НИКОГДА не добавляйте .env в git!
# =============================================================

# Базовый URL тестируемого приложения
BASE_URL=https://example.com

# URL API (если отличается от BASE_URL)
API_URL=https://api.example.com

# Учётные данные тестового пользователя
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=your_test_password_here

# Учётные данные администратора
ADMIN_USER_EMAIL=admin@example.com
ADMIN_USER_PASSWORD=your_admin_password_here

# Таймаут по умолчанию (в миллисекундах)
DEFAULT_TIMEOUT=30000

# Режим запуска браузера (true = без GUI, false = с GUI)
HEADLESS=true
